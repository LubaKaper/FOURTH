# OpenRouter — primary live email generation (outbound_generator.py)
OPENROUTER_API_KEY=your_key_here
OPENROUTER_MODEL=poolside/laguna-m.1:free
OPENROUTER_TIMEOUT_SECONDS=5
OPENROUTER_MAX_TOKENS=2000

# Anthropic — fallback live email generation (outbound_generator.py)
ANTHROPIC_API_KEY=your_key_here
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# SMTP — required only for `--send` mode (mailer.py); review mode never uses these
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=you@example.com
SMTP_PASSWORD=secret
SMTP_FROM_EMAIL=you@example.com
SMTP_TO_EMAIL=recipient@hospital.com
